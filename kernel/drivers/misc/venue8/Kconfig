config DELL_VENUE8_MODEM_CONTROL
	tristate "Dell Venue 8 3840 modem control driver"
	depends on X86_INTEL_MID
	depends on INTEL_SCU_IPC
	depends on GPIOLIB
	help
	  Control driver for the Intel XMM 7160 LTE modem on the Dell
	  Venue 8 3840 tablet. Manages modem power via GPIO and Basin Cove
	  PMIC, and provides /dev/mdm_ctrl for the userspace modem manager
	  (mmgr) to control modem state.

	  To compile this driver as a module, choose M here: the module
	  will be called modem_control.

config DELL_VENUE8_EHCI_HSIC
	tristate "Dell Venue 8 3840 EHCI HSIC companion driver"
	depends on X86_INTEL_MID
	depends on USB_EHCI_PCI
	help
	  Companion driver for the EHCI HSIC controller that connects
	  to the Intel XMM 7160 modem on the Dell Venue 8 3840. Provides
	  HSIC PHY initialization and sysfs interface for the modem
	  manager (mmgr) to enable/disable the USB link.

	  To compile this driver as a module, choose M here: the module
	  will be called ehci_hsic.

config DELL_VENUE8_CAMERA
	tristate "Dell Venue 8 3840 camera platform glue"
	depends on X86_INTEL_MID
	depends on INTEL_SCU_IPC
	depends on VIDEO_ATOMISP || VIDEO_V4L2
	depends on GPIOLIB
	help
	  Camera sensor platform glue for the Dell Venue 8 3840.
	  Provides power sequencing, clock control, and CSI-2 configuration
	  callbacks for the OV5693 (rear, 5MP) and OV2722 (front, 2MP)
	  cameras connected to the Merrifield ISP2400 via MIPI CSI-2.

	  To compile this driver as a module, choose M here: the module
	  will be called venue8_camera.
